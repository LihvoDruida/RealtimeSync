{
  "schemaVersion": 1,
  "id": "realtime",
  "version": "${version}",
  "name": "RealtimeSync",
  "description": "Synchronizes Minecraft world time with real system time or a configurable custom day length.",
  "authors": [
    "melles1991"
  ],
  "contact": {
    "homepage": "https://github.com/LihvoDruida/RealtimeSync",
    "sources": "https://github.com/LihvoDruida/RealtimeSync"
  },
  "license": "CC0-1.0",
  "icon": "assets/realtime/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.realtime.fabric.RealtimeFabric"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "${minecraft_version_range_fabric}",
    "java": ">=${java_version}",
    "fabric-api": ">=${fabric_api_min_version}"
  },
  "custom": {
    "modmenu": {
      "badges": ["library"]
    }
  }
}
